3.1 support_reports (user-visible portion + private bundle)
CREATE TABLE public.support_reports (
  id              uuid NOT NULL DEFAULT gen_random_uuid(),
  -- user-supplied
  title           text,
  description     text NOT NULL,
  category        text DEFAULT 'bug'
                    CHECK (category IN ('bug','question','suggestion','visual','data','other')),
  -- attachment (screenshot) — stored in bucket, path only here
  screenshot_path text,                       -- e.g. support-reports/{id}/screenshot.png
  -- reporter identity (denormalised snapshot; FK kept loose to survive user deletion)
  reporter_user_id   integer,                 -- REFERENCES users(user_id), nullable
  reporter_username  text,
  reporter_roles     text[],                  -- snapshot of roles at report time
  -- triage
  status          text NOT NULL DEFAULT 'new'
                    CHECK (status IN ('new','triaged','in_progress','resolved','wont_fix','duplicate')),
  severity        text DEFAULT 'unset'
                    CHECK (severity IN ('unset','low','medium','high','critical')),
  assigned_to     integer,                    -- REFERENCES users(user_id)
  -- linkage
  route           text,                       -- router.asPath at report time
  section_key     text,                       -- nearest data-dev-section-key (code ownership anchor)
  source_file     text,                       -- resolved from DEV_LAYOUT_SECTION_SOURCE_MAP
  source_line     integer,
  -- code-state pinning (Phase 5)
  app_version     text,                        -- package.json version
  commit_sha      text,                        -- VERCEL_GIT_COMMIT_SHA
  commit_ref      text,                        -- branch
  build_id        text,                        -- Next.js buildId
  -- the private diagnostic blob (already sanitised before insert)
  diagnostics     jsonb NOT NULL DEFAULT '{}'::jsonb,
  created_at      timestamp with time zone DEFAULT now(),
  updated_at      timestamp with time zone DEFAULT now(),
  CONSTRAINT support_reports_pkey PRIMARY KEY (id),
  CONSTRAINT support_reports_reporter_fkey FOREIGN KEY (reporter_user_id) REFERENCES public.users(user_id),
  CONSTRAINT support_reports_assigned_fkey FOREIGN KEY (assigned_to) REFERENCES public.users(user_id)
);
CREATE INDEX support_reports_status_idx   ON public.support_reports (status, created_at DESC);
CREATE INDEX support_reports_reporter_idx ON public.support_reports (reporter_user_id);
CREATE INDEX support_reports_section_idx  ON public.support_reports (section_key);
