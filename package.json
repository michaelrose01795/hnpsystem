    "next-auth": "^4.24.13",
    "nodemailer": "^7.0.13",
    "pdfjs-dist": "^5.4.394",
    "postcss": "^8.5.6",
    "react": "^19.2.1",
    "react-big-calendar": "^1.19.4",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "^19.2.1",
    "react-pdf": "^10.2.0",
    "react-select": "^5.10.2",
