{
  "name": "hnpsystem",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "presentation:sync": "node tools/scripts/sync-presentation-ui.js",
    "predev": "npm run presentation:sync && npm run check:dropdowns && node tools/scripts/use-local-next-cache.js",
    "prebuild": "npm run presentation:sync && npm run check:dropdowns",
    "dev": "next dev --webpack",
    "vercel:dev": "node tools/scripts/vercel-dev.js",
    "lint": "eslint .",
    "uk:check": "node tools/scripts/enforce-uk-english.js",
    "uk:check:all": "node tools/scripts/enforce-uk-english.js --all",
    "uk:fix": "node tools/scripts/enforce-uk-english.js --fix",
    "check:encoding": "node tools/scripts/check-encoding.js",
    "check:layers": "node tools/scripts/check-layers.js",
    "check:borders": "node tools/scripts/check-borders.js",
    "check:dropdowns": "node tools/scripts/check-dropdowns.js",
    "check:report-events": "node tools/scripts/check-report-events.js",
    "check:feedback": "node tools/scripts/check-feedback.js",
    "validate:reporting": "vitest run src/lib/reporting/validation",
    "dev-layout:source-map": "node tools/scripts/generate-dev-layout-section-source-map.js",
    "build": "next build",
    "start": "next start",
    "backfill:vhc-severity": "node tools/scripts/backfill-vhc-severity.js",
    "migrate:add-severity": "node tools/scripts/run-migration-add-severity.js",
    "seed:labour-presets": "node tools/scripts/seed-labour-presets.js",
    "seed:parts-search-presets": "node tools/scripts/seed-parts-search-presets.js",
    "seed:job-request-presets": "node tools/scripts/seed-job-request-presets.js",
    "seed:website-content": "node tools/scripts/seed-website-content.mjs",
    "db:seed": "node tools/scripts/db-seed.js",
    "retention:dry-run": "node tools/scripts/run-retention.js",
    "retention:apply": "node tools/scripts/run-retention.js --apply",
    "test": "npx playwright test",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:smoke": "npx playwright test --project=auth-setup --project=smoke",
    "test:workflows": "npx playwright test --project=auth-setup --project=workflows",
    "test:visual": "npx playwright test --project=auth-setup --project=visual",
    "test:report": "npx playwright show-report",
    "verify": "node tools/scripts/verify.js"
  },
  "dependencies": {
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@react-three/postprocessing": "^3.0.4",
    "@supabase/supabase-js": "^2.81.1",
    "autoprefixer": "^10.4.21",
    "bcryptjs": "^3.0.3",
    "chart.js": "^4.5.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.3",
    "gsap": "^3.15.0",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "jwt-decode": "^4.0.0",
    "next": "^16.2.11",
    "next-auth": "^4.24.14",
    "nodemailer": "^9.0.1",
    "pdfjs-dist": "^5.4.394",
    "postcss": "^8.5.15",
    "postprocessing": "^6.39.1",
    "react": "^19.2.1",
    "react-big-calendar": "^1.20.0",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "^19.2.1",
    "react-pdf": "^10.2.0",
    "stripe": "^17.5.0",
    "swr": "^2.4.1",
    "tailwindcss": "^4.1.17",
    "three": "^0.184.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@playwright/test": "^1.58.2",
    "@types/node": "24.10.0",
    "baseline-browser-mapping": "^2.9.17",
    "eslint": "^9.38.0",
    "eslint-config-next": "^16.1.6",
    "playwright": "^1.58.2",
    "typescript": "5.9.3",
    "vitest": "^4.1.5"
  },
  "overrides": {
    "dompurify": "3.4.7",
    "lodash": "4.18.1",
    "lodash-es": "4.18.1",
    "next": {
      "postcss": "8.5.15"
    },
    "next-auth": {
      "uuid": "11.1.1"
    },
    "micromatch": {
      "picomatch": "2.3.2"
    },
    "minimatch@3": {
      "brace-expansion": "1.1.14"
    },
    "minimatch@10": {
      "brace-expansion": "5.0.6"
    },
    "@supabase/realtime-js": {
      "ws": "8.21.0"
    },
    "vite": {
      "yaml": "2.9.0"
    }
  }
}
