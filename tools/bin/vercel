#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"
NODE_BIN="node"
IS_WINDOWS_NODE=0

if ! command -v "$NODE_BIN" >/dev/null 2>&1; then
  if [[ -x "/mnt/c/Program Files/nodejs/node.exe" ]]; then
    NODE_BIN="/mnt/c/Program Files/nodejs/node.exe"
    IS_WINDOWS_NODE=1
  fi
fi

node_path() {
  if [[ "$IS_WINDOWS_NODE" -eq 1 ]] && command -v wslpath >/dev/null 2>&1; then
    wslpath -w "$1"
    return
  fi
  printf '%s\n' "$1"
}

if [[ "${1:-}" == "dev" ]]; then
  shift
  exec "$NODE_BIN" "$(node_path "$ROOT_DIR/tools/scripts/vercel-dev.js")" "$@"
fi

if [[ -f "$ROOT_DIR/node_modules/vercel/dist/vc.js" ]]; then
  exec "$NODE_BIN" "$(node_path "$ROOT_DIR/node_modules/vercel/dist/vc.js")" "$@"
fi

exec npx --yes vercel "$@"
